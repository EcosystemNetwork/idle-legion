# Copy to .env.local for local dev. Every var below that a deploy needs must ALSO
# exist as a GitHub repo secret of the SAME NAME — .github/workflows/deploy.yml
# injects them at build time (Settings > Secrets and variables > Actions).

# Particle Network — https://dashboard.particle.network/
VITE_PARTICLE_PROJECT_ID=
VITE_PARTICLE_CLIENT_KEY=
VITE_PARTICLE_APP_ID=

# Magic Labs embedded wallet — https://dashboard.magic.link/
VITE_MAGIC_PUBLISHABLE_KEY=

# Optional: destination for War Chest funding demo (defaults to connected address)
# VITE_WAR_CHEST_RECEIVER=

# InsForge backend — REST base for telemetry ingest, cloud saves and the admin
# analytics dashboard. Leave blank to disable analytics entirely (the game and
# every offline system still work).
VITE_INSFORGE_URL=
# Reserved: not read by the client today (edge functions are public endpoints).
VITE_INSFORGE_ANON_KEY=

# InsForge edge-function base URL — powers real multiplayer (World Boss, PvP
# ladder) + cloud save + the Operator missions. Has a sensible default baked in;
# override only to point at a different InsForge project's functions host.
# VITE_INSFORGE_FN_URL=https://<appkey>.function2.insforge.app

# Build-time only: public base path. Defaults to "/". CI sets this for GitHub
# Pages, which serves from /<repo>/. Not needed for local dev.
# VITE_BASE=/idle-legion/
